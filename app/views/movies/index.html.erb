<% if user_signed_in? %>
  <!-- AUTHENTICATED USER VIEW - My Movies Collection -->
  <div class="container mt-5 mb-5">
    <div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3 mb-5">
      <div>
        <h1 style="margin: 0; font-size: 2.5rem; background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">My Collection</h1>
        <small style="font-size: 1.05rem; color: #64748B; font-weight: 500; display: block; margin-top: 0.5rem;">
          <%= @movies.count %> movie<%= 's' if @movies.count != 1 %> in your library
        </small>
      </div>
      <%= link_to '+ Discover & Add Movies', new_movie_path, class: 'btn btn-primary btn-lg', style: 'padding: 0.75rem 2rem; font-size: 1rem;' %>
    </div>

    <!-- Search Bar -->
    <div style="margin-bottom: 2rem;">
      <div class="search-box-wrapper" style="position: relative;">
        <input type="text" id="collection-search" placeholder="🔍 Search your collection..." class="form-control" style="display: none;">
        <span id="search-toggle-btn" class="btn btn-light" style="width: 100%; text-align: left; cursor: pointer; border: 2px solid #E2E8F0; padding: 0.75rem 1.25rem; transition: all 0.3s ease;">
          🔍 Search your collection...
        </span>
      </div>
    </div>

    <% if @movies.empty? %>
      <!-- Empty State -->
      <div class="empty-state" style="margin-top: 4rem; padding: 4rem 2rem; text-align: center; background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(236, 72, 153, 0.05) 100%); border-radius: 16px; border: 2px dashed #E2E8F0;">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🎬</div>
        <h4 style="font-size: 1.75rem; margin-bottom: 0.5rem; color: #0F172A;">Your collection is empty</h4>
        <p style="font-size: 1.05rem; color: #64748B; margin-bottom: 2rem; max-width: 400px; margin-left: auto; margin-right: auto;">Start building your collection by discovering movies and sharing your ratings with the community!</p>
        <%= link_to '✨ Find Your First Movie', new_movie_path, class: 'btn btn-primary btn-lg' %>
      </div>
    <% else %>
      <!-- Movies Grid -->
      <div class="row g-4">
        <% @movies.each do |movie| %>
          <div class="col-md-6 col-lg-4 col-xl-3 movie-item">
            <div class="card movie-card h-100" style="border: none; border-radius: 12px; overflow: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);">
              <%= link_to movie_path(movie), style: "text-decoration: none; color: inherit;" do %>
                <!-- Movie Poster -->
                <div class="card-img-wrapper position-relative" style="height: 300px; overflow: hidden; background: linear-gradient(135deg, #F0F4F8 0%, #E2E8F0 100%);">
                  <% if movie.poster_path.present? %>
                    <img src="<%= movie.poster_url %>" class="card-img-top" alt="<%= movie.title %>" style="height: 100%; width: 100%; object-fit: cover; transition: transform 0.3s ease;">
                  <% else %>
                    <div class="d-flex align-items-center justify-content-center h-100">
                      <span style="font-size: 3rem; opacity: 0.5;">📽️</span>
                    </div>
                  <% end %>
                  
                  <!-- Rating Badge -->
                  <div class="rating-badge" style="position: absolute; top: 12px; right: 12px; background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%); color: white; padding: 0.5rem 0.75rem; border-radius: 8px; font-weight: 700; font-size: 0.9rem; box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);">
                    <% avg_rating = movie.ratings.average(:score)&.round(1) %>
                    <% if avg_rating %>
                      ⭐ <%= avg_rating %>
                    <% else %>
                      ★ New
                    <% end %>
                  </div>
                </div>
              <% end %>
              
              <div class="card-body d-flex flex-column" style="padding: 1.25rem;">
                <!-- Title -->
                <h5 class="card-title" style="margin-bottom: 0.5rem; min-height: 2.5rem; font-size: 1.1rem;">
                  <%= link_to movie.title, movie_path(movie), style: 'text-decoration: none; color: #0F172A; transition: color 0.3s;', onmouseover: "this.style.color='#8B5CF6'", onmouseout: "this.style.color='#0F172A'" %>
                </h5>
                
                <!-- Meta Information -->
                <div style="margin-bottom: 1rem; flex-grow: 1;">
                  <small style="color: #64748B; display: block; font-weight: 500;">📅 <%= movie.release_date&.year %></small>
                  <small style="color: #94A3B8; display: block; margin-top: 0.25rem;">Added <%= time_ago_in_words(movie.created_at) %> ago</small>
                  <% if movie.description.present? %>
                    <p class="card-text" style="margin-top: 0.75rem; margin-bottom: 0; color: #64748B; font-size: 0.95rem; line-height: 1.4;">
                      <%= truncate(movie.description, length: 85) %>
                    </p>
                  <% end %>
                </div>

                <!-- User Rating Info -->
                <div style="margin-top: auto; border-top: 1px solid #E2E8F0; padding-top: 1rem;">
                  <% current_user_rating = movie.ratings.find_by(user: current_user) if user_signed_in? %>
                  <% if current_user_rating %>
                    <div class="mb-3">
                      <small style="background: linear-gradient(135deg, #10B981 0%, #059669 100%); color: white; padding: 0.4rem 0.8rem; border-radius: 16px; font-weight: 600; display: inline-block; box-shadow: 0 2px 8px rgba(16, 185, 129, 0.2);">
                        ✓ Your rating: <%= current_user_rating.score %>/10
                      </small>
                    </div>
                  <% else %>
                    <div class="mb-3">
                      <small style="color: #94A3B8; font-weight: 500;">Not rated by you yet</small>
                    </div>
                  <% end %>
                  <%= link_to 'View & Rate', movie_path(movie), class: 'btn btn-sm btn-primary w-100' %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <style>
    .movie-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 30px rgba(139, 92, 246, 0.2) !important;
    }

    .movie-item {
      transition: transform 0.3s ease;
    }

    .movie-item:hover {
      transform: scale(1.02);
    }

    #collection-search {
      width: 100%;
      padding: 0.75rem 1.25rem;
      border: 2px solid #E2E8F0;
      border-radius: 8px;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    #collection-search:focus {
      outline: none;
      border-color: #8B5CF6;
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const searchToggle = document.getElementById('search-toggle-btn');
      const searchInput = document.getElementById('collection-search');
      const movieItems = document.querySelectorAll('.movie-item');

      // Toggle search input visibility
      searchToggle.addEventListener('click', function() {
        searchInput.style.display = searchInput.style.display === 'none' ? 'block' : 'none';
        if (searchInput.style.display === 'block') {
          searchInput.focus();
        } else {
          searchInput.value = '';
          movieItems.forEach(item => item.style.display = '');
        }
      });

      // Search functionality
      searchInput.addEventListener('input', function() {
        const query = this.value.toLowerCase();
        movieItems.forEach(item => {
          const title = item.querySelector('.card-title').textContent.toLowerCase();
          item.style.display = title.includes(query) ? '' : 'none';
        });
      });
    });
  </script>

<% else %>
  <!-- UNAUTHENTICATED USER - LANDING PAGE -->
  <style>
    .landing-hero {
      background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
      color: white;
      padding: 6rem 0;
      position: relative;
      overflow: hidden;
    }

    .landing-hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      opacity: 0.1;
    }

    .landing-content {
      position: relative;
      z-index: 1;
    }

    .landing-title {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    .landing-subtitle {
      font-size: 1.4rem;
      opacity: 0.95;
      margin-bottom: 2rem;
      max-width: 600px;
    }

    .auth-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .search-section {
      margin: 3rem 0;
      padding: 2rem;
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(139, 92, 246, 0.15);
    }

    .search-section h3 {
      margin-bottom: 1.5rem;
      color: #0F172A;
      font-size: 1.5rem;
    }

    .search-input-wrapper {
      display: flex;
      gap: 0.5rem;
    }

    .search-input-wrapper input {
      flex: 1;
      padding: 0.75rem 1.25rem;
      border: 2px solid #E2E8F0;
      border-radius: 8px;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .search-input-wrapper input:focus {
      outline: none;
      border-color: #8B5CF6;
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
    }

    .search-input-wrapper button {
      padding: 0.75rem 2rem;
      background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
    }

    .search-input-wrapper button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4);
    }

    .trending-section {
      margin-top: 4rem;
      padding: 0;
    }

    .trending-title {
      font-size: 2rem;
      margin-bottom: 2rem;
      color: #0F172A;
      font-weight: 800;
    }

    .movie-card-landing {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      height: 100%;
    }

    .movie-card-landing:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 30px rgba(139, 92, 246, 0.2);
    }

    .movie-card-landing .card-img-wrapper {
      height: 250px;
      background: linear-gradient(135deg, #F0F4F8 0%, #E2E8F0 100%);
      overflow: hidden;
      position: relative;
    }

    .movie-card-landing img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .movie-card-landing:hover img {
      transform: scale(1.05);
    }

    .movie-card-landing .card-body {
      padding: 1.25rem;
    }

    .movie-card-landing .card-body h5 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #0F172A;
    }

    .movie-card-landing .card-body small {
      color: #64748B;
    }

    .cta-section {
      text-align: center;
      padding: 4rem 2rem;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(236, 72, 153, 0.05) 100%);
      border-radius: 12px;
      margin-top: 4rem;
    }

    .cta-section h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: #0F172A;
    }

    .cta-section p {
      font-size: 1.1rem;
      color: #64748B;
      margin-bottom: 2rem;
    }
  </style>

  <!-- Hero Section -->
  <div class="landing-hero">
    <div class="container landing-content">
      <div style="max-width: 600px;">
        <h1 class="landing-title">🎬 MovieGauge</h1>
        <p class="landing-subtitle">Discover movies, rate them, and see what the community thinks. Your personal film guide awaits.</p>
        <div class="auth-buttons">
          <%= link_to 'Sign In', new_user_session_path, class: 'btn btn-light btn-lg', style: 'font-weight: 600; color: #8B5CF6;' %>
          <%= link_to 'Create Account', new_user_registration_path, class: 'btn btn-light btn-lg', style: 'font-weight: 600; color: #8B5CF6;' %>
        </div>
      </div>
    </div>
  </div>

  <!-- Search Section -->
  <div class="container">
    <div class="search-section">
      <h3>🔍 Search & Discover</h3>
      <div class="search-input-wrapper">
        <input type="text" id="tmdb-search" placeholder="Search for a movie..." autocomplete="off">
        <button id="search-btn" type="button">Search</button>
      </div>
      <div id="search-results" style="margin-top: 2rem;"></div>
    </div>

    <!-- Trending Movies Section -->
    <div class="trending-section">
      <h2 class="trending-title">🌟 Popular Movies</h2>
      <div class="row g-4" id="popular-movies">
        <div style="text-align: center; width: 100%; padding: 2rem;">
          <p style="color: #64748B; font-weight: 500;">Loading popular movies...</p>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="cta-section">
      <h2>Ready to Start Rating?</h2>
      <p>Join thousands of movie enthusiasts and build your personalized film collection.</p>
      <div class="auth-buttons" style="justify-content: center;">
        <%= link_to 'Sign Up Now', new_user_registration_path, class: 'btn btn-primary btn-lg' %>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Load popular movies on page load
      loadPopularMovies();

      // Search functionality
      const searchInput = document.getElementById('tmdb-search');
      const searchBtn = document.getElementById('search-btn');
      const searchResults = document.getElementById('search-results');

      searchBtn.addEventListener('click', performSearch);
      searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') performSearch();
      });

      function performSearch() {
        const query = searchInput.value.trim();
        if (query.length < 2) {
          searchResults.innerHTML = '<p style="color: #94A3B8; text-align: center;">Please enter at least 2 characters</p>';
          return;
        }

        fetch(`<%= search_movies_path %>?q=${encodeURIComponent(query)}`)
          .then(response => response.json())
          .then(movies => displayMovies(movies, searchResults))
          .catch(error => {
            searchResults.innerHTML = '<p style="color: #EF4444; text-align: center;">Search failed. Please try again.</p>';
          });
      }

      function loadPopularMovies() {
        // This would require a separate action to fetch popular movies from TMDB
        // For now, show placeholder
        document.getElementById('popular-movies').innerHTML = `
          <div style="text-align: center; width: 100%; padding: 3rem;">
            <p style="color: #64748B; font-weight: 500;">Popular movies will be displayed here</p>
            <p style="color: #94A3B8; font-size: 0.95rem;">Sign in to search and rate movies!</p>
          </div>
        `;
      }

      function displayMovies(movies, container) {
        if (movies.length === 0) {
          container.innerHTML = '<p style="color: #94A3B8; text-align: center;">No movies found. Try another search.</p>';
          return;
        }

        let html = '<div class="row g-4">';
        movies.forEach(movie => {
          html += `
            <div class="col-md-6 col-lg-4">
              <div class="movie-card-landing">
                <div class="card-img-wrapper">
                  ${movie.poster_path ? `<img src="https://image.tmdb.org/t/p/w500${movie.poster_path}" alt="${movie.title}">` : '<div style="display: flex; align-items: center; justify-content: center; height: 100%;"><span style="font-size: 3rem; opacity: 0.5;">📽️</span></div>'}
                </div>
                <div class="card-body">
                  <h5>${movie.title}</h5>
                  <small>📅 ${new Date(movie.release_date).getFullYear()}</small>
                  <p style="margin-top: 0.75rem; color: #64748B; font-size: 0.95rem;">⭐ ${movie.vote_average ? movie.vote_average.toFixed(1) : 'N/A'}/10</p>
                  <p style="font-size: 0.9rem; color: #94A3B8;">${movie.overview ? movie.overview.substring(0, 80) + '...' : 'No description'}</p>
                  <p style="margin-top: 1rem; text-align: center; color: #8B5CF6; font-weight: 600; font-size: 0.9rem;">📝 Sign in to rate this movie</p>
                </div>
              </div>
            </div>
          `;
        });
        html += '</div>';
        container.innerHTML = html;
      }
    });
  </script>
<% end %>