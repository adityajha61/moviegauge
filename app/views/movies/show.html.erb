<div class="container mt-5">
  <div class="row">
    <div class="col-md-8">
      <h1><%= @movie.title %></h1>
      
      <div class="mt-4 mb-4">
        <p><strong>Release Date:</strong> <%= @movie.release_date.strftime("%B %d, %Y") if @movie.release_date %></p>
        <p><strong>Description:</strong></p>
        <p><%= @movie.description %></p>
      </div>

      <hr>

      <div class="mt-4">
        <h3>Ratings</h3>
        <% if @movie.ratings.any? %>
          <p><strong>Average Rating:</strong> <%= @movie.ratings.average(:score)&.round(1) || "N/A" %>/10</p>
          <p><strong>Total Ratings:</strong> <%= @movie.ratings.count %></p>
        <% else %>
          <p>No ratings yet.</p>
        <% end %>
      </div>

      <div class="mt-4">
        <h4>Rate This Movie:</h4>
        <%= form_with(model: [@movie, @rating], local: true) do |form| %>
          <% if @rating.errors.any? %>
            <div class="alert alert-danger">
              <h4><%= pluralize(@rating.errors.count, "error") %> prohibited this rating from being saved:</h4>
              <ul>
                <% @rating.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= form.label :score, "Your Rating (1-10)", class: "form-label" %>
            <%= form.number_field :score, min: 1, max: 10, class: "form-control", style: "max-width: 150px;" %>
          </div>

          <%= form.submit "Submit Rating", class: "btn btn-success" %>
        <% end %>
      </div>

      <div class="mt-5">
        <%= link_to "Edit", edit_movie_path(@movie), class: "btn btn-warning" %>
        <%= link_to "Delete", movie_path(@movie), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
        <%= link_to "Back to Movies", movies_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>
