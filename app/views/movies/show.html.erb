<div class="container mt-4 mb-5 movie-show-page">
  <!-- Back Button -->
  <div style="margin-bottom: 2rem;">
    <%= link_to "← Back", movies_path, class: "btn btn-light" %>
  </div>

  <!-- SIGN IN WARNING FOR UNAUTHENTICATED USERS -->
  <% if !user_signed_in? %>
    <div class="signin-warning-banner" style="background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%); color: white; padding: 2.5rem; border-radius: 12px; margin-bottom: 3rem; box-shadow: 0 10px 30px rgba(139, 92, 246, 0.2);">
      <div class="signin-warning-header" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
        <span style="font-size: 2rem;">📝</span>
        <h3 style="font-weight: 700; margin: 0;">Sign In to Rate & Add to Your Collection</h3>
      </div>
      <p style="margin-bottom: 1.5rem; font-size: 1.05rem; opacity: 0.95;">Join our community, rate this movie, add it to your watched list, and discover what other film enthusiasts think.</p>
      <div class="signin-warning-actions" style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <%= link_to "Sign In", new_user_session_path, class: "btn btn-light", style: "font-weight: 600; color: #8B5CF6;" %>
        <%= link_to "Create Account", new_user_registration_path, class: "btn btn-light", style: "font-weight: 600; color: #8B5CF6;" %>
      </div>
    </div>
  <% end %>

  <div class="movie-details">
    <!-- Movie Poster & Info -->
    <div class="movie-show-left-column">
      <% if @movie.poster_path.present? %>
        <div class="movie-poster" style="max-width: 280px; width: 100%; aspect-ratio: 2 / 3;">
          <img src="<%= "https://image.tmdb.org/t/p/w500#{@movie.poster_path}" %>" alt="<%= @movie.title %>" style="width: 100%; height: 100%; object-fit: cover; display: block;">
        </div>
      <% else %>
        <div class="movie-poster movie-poster-placeholder bg-light d-flex align-items-center justify-content-center" style="max-width: 280px; width: 100%; aspect-ratio: 2 / 3;">
          <span style="font-size: 4rem; opacity: 0.5;">📽️</span>
        </div>
      <% end %>
      
      <!-- Info Card -->
      <div class="card border-0 shadow-sm mt-4" style="border-radius: 12px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(139, 92, 246, 0.02) 100%); border: 1px solid rgba(139, 92, 246, 0.1);">
        <div class="card-body">
          <h6 class="fw-bold mb-2" style="color: #8B5CF6; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px;">Added to MovieGauge</h6>
          <p style="font-size: 1.1rem; color: #0F172A; font-weight: 600; margin-bottom: 0;">📅 <%= @movie.created_at.strftime("%B %d, %Y") %></p>
        </div>
      </div>
    </div>

    <!-- Movie Details -->
    <div class="movie-info">
      <h1 style="margin-bottom: 1rem; background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"><%= @movie.title %></h1>
      
      <!-- Meta Info -->
      <div class="movie-meta">
        <div class="meta-item">
          <span>📅</span>
          <small><%= @movie.release_date.strftime("%B %d, %Y") if @movie.release_date %></small>
        </div>
        <% if @movie.vote_average.present? %>
          <div class="meta-item">
            <span>⭐</span>
            <small><strong><%= @movie.vote_average %></strong>/10 (TMDB)</small>
          </div>
        <% end %>
      </div>

      <!-- Overview -->
      <div class="overview-section">
        <h5>Overview</h5>
        <p><%= @movie.description %></p>
      </div>

      <!-- Community Ratings -->
      <div class="rating-card">
        <h5 style="color: #0F172A; margin-bottom: 1rem;">👥 Community Average</h5>
        <% if @movie.ratings.any? %>
          <div class="rating-average">
            <%= @movie.ratings.average(:score)&.round(1) %>
            <span style="font-size: 1.5rem; color: #94A3B8; font-weight: 400;">/10</span>
          </div>
          <p class="rating-count">
            Based on <strong><%= @movie.ratings.count %></strong> rating<%= 's' if @movie.ratings.count != 1 %>
          </p>
        <% else %>
          <div style="padding: 2rem; background: white; border-radius: 8px; text-align: center; border: 1px solid #E2E8F0;">
            <p style="color: #64748B; margin-bottom: 0;">No ratings yet — be the first to share your thoughts! 🎯</p>
          </div>
        <% end %>
      </div>

      <!-- User Rating Section -->
      <% if user_signed_in? %>
        <% current_user_rating = @movie.ratings.find_by(user: current_user) %>
        
        <% if current_user_rating %>
          <!-- User Already Rated -->
          <div class="user-rating-card">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
              <div>
                <h5 style="margin-bottom: 1rem; color: #92400E;">⭐ Your Rating</h5>
                <div class="rating-average" style="font-size: 2.5rem; color: #F59E0B; margin-bottom: 0;">
                  <%= current_user_rating.score %>
                  <span style="font-size: 1rem; color: #D97706; font-weight: 400;">/10</span>
                </div>
                <small style="color: #92400E; opacity: 0.7;">Rated on <%= current_user_rating.created_at.strftime("%B %d, %Y at %l:%M %p") %></small>
              </div>
              <div>
                <%= link_to "Edit Rating", edit_movie_rating_path(@movie, current_user_rating), class: "btn btn-warning", style: "padding: 0.5rem 1.5rem;" %>
              </div>
            </div>
          </div>
        <% else %>
          <!-- User Can Rate -->
          <div class="card border-0 shadow-sm" style="border-radius: 12px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(139, 92, 246, 0.02) 100%); border: 1px solid rgba(139, 92, 246, 0.1);">
            <div class="card-body">
              <h5 class="fw-bold mb-4">⭐ Share Your Rating</h5>
              <%= form_with(model: [@movie, @rating], local: true) do |form| %>
                <% if @rating.errors.any? %>
                  <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%); border: 1px solid #FECACA; color: #991B1B; font-weight: 500;">
                    <strong>⚠️ Cannot Save Rating:</strong>
                    <ul class="mb-0 mt-2">
                      <% @rating.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                    <button type="button" class="btn-close" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 16 16\"><path fill=\"%23991B1B\" d=\"M.293.293a1 1 0 0 1 1.414 0L8 6.586 14.293.293a1 1 0 1 1 1.414 1.414L9.414 8l6.293 6.293a1 1 0 0 1-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 0 1-1.414-1.414L6.586 8 .293 1.707a1 1 0 0 1 0-1.414z\"/></svg>');" data-bs-dismiss="alert"></button>
                  </div>
                <% end %>

                <div class="mb-4">
                  <%= form.label :score, "What's your rating?", class: "form-label fw-bold mb-3" %>
                  <div class="d-flex align-items-center gap-2" style="background: white; padding: 1rem; border-radius: 8px; border: 2px solid #E2E8F0; transition: all 0.3s ease;">
                    <%= form.number_field :score, min: 1, max: 10, class: "form-control form-control-lg", style: "max-width: 120px; font-weight: 600; font-size: 1.25rem; border: none; padding: 0.5rem; text-align: center;", placeholder: "1-10", required: true %>
                    <span style="font-weight: 700; color: #64748B; font-size: 1.25rem;">/10</span>
                  </div>
                  <small style="display: block; margin-top: 0.75rem; color: #64748B;"><strong>1</strong> = Didn't enjoy • <strong>10</strong> = Absolutely loved it!</small>
                </div>

                <div class="d-flex gap-2" style="flex-wrap: wrap;">
                  <%= form.submit "Save Rating", class: "btn btn-primary", style: "padding: 0.75rem 2rem; font-weight: 600;" %>
                  <%= link_to "Cancel", movies_path, class: "btn btn-light", style: "padding: 0.75rem 2rem;" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Action Buttons (only for signed in users) -->
        <div class="movie-show-actions" style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #E2E8F0;">
          <%= link_to "✏️ Edit", edit_movie_path(@movie), class: "btn btn-warning", style: "padding: 0.75rem 1.5rem;" %>
          <%= link_to "🗑️ Delete", movie_path(@movie), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "padding: 0.75rem 1.5rem;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
