<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h1 class="mb-4">Add New Movie</h1>

      <%= form_with(model: @movie, local: true) do |form| %>
        <% if @movie.errors.any? %>
          <div class="alert alert-danger">
            <h4><%= pluralize(@movie.errors.count, "error") %> prohibited this movie from being saved:</h4>
            <ul>
              <% @movie.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= form.label :title, class: "form-label" %>
          <%= form.text_field :title, class: "form-control", placeholder: "Enter movie title" %>
        </div>

        <div class="mb-3">
          <%= form.label :description, class: "form-label" %>
          <%= form.text_area :description, rows: 5, class: "form-control", placeholder: "Enter movie description" %>
        </div>

        <div class="mb-3">
          <%= form.label :release_date, class: "form-label" %>
          <%= form.date_field :release_date, class: "form-control" %>
        </div>

        <div class="d-flex gap-2">
          <%= form.submit "Add Movie", class: "btn btn-primary" %>
          <%= link_to "Cancel", movies_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
