<div class="container mt-4 mb-5">
  <div style="margin-bottom: 2rem;">
    <%= link_to "← Back to Movies", movies_path, class: "btn btn-light" %>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-body p-5">
          <h1 class="mb-2 fw-bold" style="font-size: 2rem;">🎬 Discover & Add Movie</h1>
          <p style="color: #64748B; margin-bottom: 2rem;">Search The Movie Database (TMDB) to find and add your favorite films</p>

          <div data-controller="movie-search">
            <!-- Search Input -->
            <div class="mb-4" style="position: relative;">
              <label class="form-label fw-bold" style="font-size: 1rem; display: block; margin-bottom: 0.75rem;">Search TMDB</label>
              <input 
                type="text" 
                class="form-control form-control-lg search-input" 
                placeholder="Start typing a movie name (e.g., The Matrix)..."
                data-movie-search-target="input"
                data-action="input->movie-search#search keydown->movie-search#handleKeydown"
                style="border-radius: 8px; border: 1px solid #E2E8F0; padding: 0.875rem 1.25rem; position: relative; z-index: 10;"
              >
              <div 
                class="search-results d-none" 
                data-movie-search-target="results"
                style="position: absolute; top: 100%; left: 0; right: 0; border-radius: 0 0 8px 8px; margin-top: 0; z-index: 1001;"
              ></div>
            </div>

            <!-- Movie Preview -->
            <div id="movie-preview" class="mt-4 mb-5"></div>

            <!-- Form -->
            <%= form_with(model: @movie, local: false, data: { "movie-search-target": "form", turbo: false }) do |form| %>
              <% if @movie.errors.any? %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%); border: 1px solid #FECACA; color: #991B1B; font-weight: 500; border-radius: 8px;">
                  <strong>⚠️ Fix these errors:</strong>
                  <ul class="mb-0 mt-2">
                    <% @movie.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                  <button type="button" class="btn-close" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 16 16\"><path fill=\"%23991B1B\" d=\"M.293.293a1 1 0 0 1 1.414 0L8 6.586 14.293.293a1 1 0 1 1 1.414 1.414L9.414 8l6.293 6.293a1 1 0 0 1-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 0 1-1.414-1.414L6.586 8 .293 1.707a1 1 0 0 1 0-1.414z\"/></svg>');" data-bs-dismiss="alert"></button>
                </div>
              <% end %>

              <!-- Hidden fields for TMDB data -->
              <%= form.hidden_field :tmdb_id, id: "movie_tmdb_id" %>
              <%= form.hidden_field :poster_path, id: "movie_poster_path" %>
              <%= form.hidden_field :backdrop_path, id: "movie_backdrop_path" %>
              <%= form.hidden_field :vote_average, id: "movie_vote_average" %>
              <%= form.hidden_field :popularity, id: "movie_popularity" %>

              <!-- Title -->
              <div class="mb-4">
                <%= form.label :title, "Movie Title", class: "form-label fw-bold" %>
                <%= form.text_field :title, class: "form-control form-control-lg #{'is-invalid' if @movie.errors[:title].any?}", placeholder: "e.g., The Shawshank Redemption", id: "movie_title", style: "border-radius: 8px; border: 1px solid #E2E8F0;" %>
                <% if @movie.errors[:title].any? %>
                  <div class="invalid-feedback d-block" style="color: #EF4444;">
                    <%= @movie.errors[:title].first %>
                  </div>
                <% end %>
              </div>

              <!-- Description -->
              <div class="mb-4">
                <%= form.label :description, "Description", class: "form-label fw-bold" %>
                <%= form.text_area :description, rows: 6, class: "form-control #{'is-invalid' if @movie.errors[:description].any?}", placeholder: "Enter a brief description of the movie...", id: "movie_description", style: "border-radius: 8px; border: 1px solid #E2E8F0;" %>
                <% if @movie.errors[:description].any? %>
                  <div class="invalid-feedback d-block" style="color: #EF4444;">
                    <%= @movie.errors[:description].first %>
                  </div>
                <% end %>
              </div>

              <!-- Release Date -->
              <div class="mb-4">
                <%= form.label :release_date, "Release Date", class: "form-label fw-bold" %>
                <%= form.date_field :release_date, class: "form-control form-control-lg #{'is-invalid' if @movie.errors[:release_date].any?}", id: "movie_release_date", style: "border-radius: 8px; border: 1px solid #E2E8F0;" %>
                <% if @movie.errors[:release_date].any? %>
                  <div class="invalid-feedback d-block" style="color: #EF4444;">
                    <%= @movie.errors[:release_date].first %>
                  </div>
                <% end %>
              </div>

              <!-- Rating (Optional) -->
              <div class="mb-5">
                <label class="form-label fw-bold">Your Rating (Optional)</label>
                <div class="d-flex align-items-center gap-3">
                  <input 
                    type="range" 
                    id="rating_slider_js" 
                    name="movie[rating_score]" 
                    min="1" 
                    max="10" 
                    value="5"
                    class="form-range"
                    style="width: 200px; cursor: pointer;"
                  >
                  <span id="rating_display_js" style="font-weight: bold; color: #8B5CF6; font-size: 1.1rem; min-width: 40px;">5/10</span>
                </div>
                <small class="text-muted" style="display: block; margin-top: 0.5rem;">Slide to rate the movie from 1 to 10, or leave at default</small>
              </div>

              <!-- Buttons -->
              <div class="d-flex gap-3 flex-wrap">
                <%= form.submit "Save Movie", class: "btn btn-primary btn-lg fw-bold", style: "padding: 0.875rem 2.5rem; border-radius: 8px; background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%); border: none; box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);" %>
                <%= link_to "Cancel", movies_path, class: "btn btn-light btn-lg", style: "padding: 0.875rem 2.5rem; border-radius: 8px;" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
  console.log('Script loaded - initializing rating slider');
  
  // Wait for DOM to be ready
  function initRatingSlider() {
    console.log('initRatingSlider called');
    const ratingSlider = document.getElementById('rating_slider_js');
    const ratingDisplay = document.getElementById('rating_display_js');
    
    console.log('Rating Slider:', ratingSlider);
    console.log('Rating Display:', ratingDisplay);
    
    if (ratingSlider && ratingDisplay) {
      // Update display when slider is moved
      ratingSlider.addEventListener('input', function(e) {
        console.log('Slider moved to:', e.target.value);
        ratingDisplay.textContent = e.target.value + '/10';
      });
      console.log('Rating slider event listener attached');
    } else {
      console.warn('Rating slider or display element not found');
    }
  }
  
  // Try to initialize as soon as possible
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRatingSlider);
  } else {
    initRatingSlider();
  }
</script>

<style>
  .search-input {
    position: relative;
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border: 1px solid #E2E8F0;
    border-top: none;
    border-radius: 0 0 8px 8px;
    max-height: 400px;
    overflow-y: auto;
    z-index: 1000;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .search-result-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 12px 16px;
    cursor: pointer;
    border-bottom: 1px solid #F1F5F9;
    transition: background-color 0.2s;
  }

  .search-result-item:last-child {
    border-bottom: none;
  }

  .search-result-item:hover,
  .search-result-item.selected {
    background-color: #F8FAFC;
  }

  .search-result-poster {
    flex-shrink: 0;
  }

  .search-result-poster img {
    width: 50px;
    height: 75px;
    object-fit: cover;
    border-radius: 6px;
  }

  .no-poster {
    width: 50px;
    height: 75px;
    background-color: #E2E8F0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    font-size: 24px;
    color: #94A3B8;
  }

  .search-result-info {
    flex-grow: 1;
  }

  .search-result-title {
    font-weight: 600;
    font-size: 14px;
    color: #0F172A;
    margin-bottom: 4px;
  }

  .search-result-meta {
    display: flex;
    gap: 12px;
    font-size: 12px;
    color: #64748B;
  }

  .search-no-results {
    padding: 24px;
    text-align: center;
    color: #94A3B8;
    font-weight: 500;
  }

  .movie-preview-card {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(236, 72, 153, 0.05) 100%);
    border-radius: 12px;
    padding: 24px;
    border: 1px solid rgba(139, 92, 246, 0.1);
  }

  .preview-content {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .preview-poster img {
    width: 120px;
    height: 180px;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    flex-shrink: 0;
    object-position: center;
  }

  .no-poster-large {
    width: 120px;
    height: 180px;
    background-color: #E2E8F0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 48px;
    color: #94A3B8;
    flex-shrink: 0;
  }

  .preview-info {
    flex-grow: 1;
  }

  .preview-info h5 {
    color: #0F172A;
    margin-bottom: 12px;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .preview-description {
    line-height: 1.6;
    max-height: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    color: #64748B;
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .preview-content {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .preview-info {
      text-align: center;
    }
  }
</style>
