<style>
  .auth-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--light-bg) 0%, #F1F5F9 100%);
  }

  [data-theme="dark"] .auth-shell {
    background: linear-gradient(135deg, #020617 0%, #0F172A 100%);
  }

  [data-theme="dark"] .auth-shell .card-body {
    background: #111827;
    color: #E2E8F0;
  }

  [data-theme="dark"] .auth-shell .form-label,
  [data-theme="dark"] .auth-shell .form-check-label {
    color: #E2E8F0;
  }

  [data-theme="dark"] .auth-shell .form-control {
    background: #0F172A !important;
    color: #E2E8F0 !important;
    border-color: #334155 !important;
  }

  [data-theme="dark"] .auth-shell .form-control::placeholder {
    color: #94A3B8;
  }

  [data-theme="dark"] .auth-shell .auth-muted,
  [data-theme="dark"] .auth-shell .auth-back-link,
  [data-theme="dark"] .auth-shell .auth-divider-text {
    color: #94A3B8 !important;
  }

  [data-theme="dark"] .auth-shell .auth-divider-line {
    background: #334155 !important;
  }

  [data-theme="dark"] .auth-shell .auth-link,
  [data-theme="dark"] .auth-shell #togglePassword {
    color: #A78BFA !important;
  }
</style>

<div class="auth-shell">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-5">
        <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
          <!-- Header -->
          <div style="background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%); padding: 3rem 1.5rem; text-align: center; color: white;">
            <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; display: inline-flex; align-items: center; gap: 0.65rem;">
              <picture>
                <source srcset="/icon.svg" type="image/svg+xml">
                <img src="/icon.png" alt="MovieGauge logo" width="44" height="44" style="border-radius: 10px; object-fit: cover; background: rgba(255, 255, 255, 0.2);">
              </picture>
              <span>MovieGauge</span>
            </h1>
            <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 0;">Welcome back, cinephile!</p>
          </div>

          <!-- Form -->
          <div class="card-body p-5">
            <%= form_with(model: resource, local: true, url: session_path(resource_name)) do |form| %>
              <!-- Email -->
              <div class="mb-4">
                <%= form.label :email, "Email Address", class: "form-label fw-bold" %>
                <%= form.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "you@example.com", style: "border-radius: 8px; border: 1px solid #E2E8F0; padding: 0.875rem 1.25rem;" %>
              </div>

              <!-- Password -->
              <div class="mb-4">
                <%= form.label :password, "Password", class: "form-label fw-bold" %>
                <div class="input-group" style="position: relative;">
                  <%= form.password_field :password, autocomplete: "current-password", id: "login_password", class: "form-control form-control-lg", placeholder: "••••••••", style: "border-radius: 8px; border: 1px solid #E2E8F0; padding: 0.875rem 1.25rem; padding-right: 2.75rem;" %>
                  <button type="button" id="togglePassword" class="btn" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #64748B; cursor: pointer; padding: 0.35rem 0.5rem; font-size: 0.8rem; font-weight: 700;" onclick="togglePasswordVisibility('login_password', 'togglePassword')">
                    Show
                  </button>
                </div>
              </div>

              <!-- Remember Me -->
              <% if devise_mapping.rememberable? %>
                <div class="mb-4 form-check">
                  <%= form.check_box :remember_me, class: "form-check-input", style: "width: 1.25rem; height: 1.25rem; cursor: pointer;" %>
                  <%= form.label :remember_me, "Keep me signed in", class: "form-check-label" %>
                </div>
              <% end %>

              <!-- Sign In Button -->
              <div class="d-grid gap-2 mb-4">
                <%= form.submit "Sign In", class: "btn btn-primary btn-lg fw-bold", style: "padding: 0.875rem; border-radius: 8px; background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%); border: none; box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);" %>
              </div>

              <!-- Divider -->
                <div style="display: flex; align-items: center; margin: 2rem 0; gap: 1rem;">
                <div class="auth-divider-line" style="flex: 1; height: 1px; background: #E2E8F0;"></div>
                <span class="auth-divider-text" style="color: #94A3B8; font-size: 0.9rem;">or</span>
                <div class="auth-divider-line" style="flex: 1; height: 1px; background: #E2E8F0;"></div>
              </div>

              <!-- Links -->
              <div class="text-center" style="font-size: 0.95rem;">
                <p class="auth-muted" style="color: #64748B; margin-bottom: 1rem;">
                  Don't have an account?
                  <%= link_to "Sign up now", new_user_registration_path, class: "auth-link", style: "color: #8B5CF6; font-weight: 600; text-decoration: none;" %>
                </p>
                <p class="auth-muted" style="color: #64748B;">
                  <%= link_to "Forgot your password?", new_user_password_path, class: "auth-link", style: "color: #8B5CF6; font-weight: 600; text-decoration: none;" %>
                </p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Back Link -->
        <div style="text-align: center; margin-top: 2rem;">
          <%= link_to "← Back to MovieGauge", root_path, class: "auth-back-link", style: "color: #64748B; text-decoration: none; font-weight: 500; transition: color 0.3s;" %>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
  function togglePasswordVisibility(fieldId, buttonId) {
    const field = document.getElementById(fieldId);
    const button = document.getElementById(buttonId);
    
    if (field.type === 'password') {
      field.type = 'text';
      button.textContent = 'Hide';
    } else {
      field.type = 'password';
      button.textContent = 'Show';
    }
  }
</script>
